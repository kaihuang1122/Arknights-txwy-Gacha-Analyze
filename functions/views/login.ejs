    </div>
    <script>
      document.getElementById('footer-menu-toggle').addEventListener('click', function(e) {
        const links = document.getElementById('footer-menu-links');
        if (links.style.display === 'none') {
          links.style.display = 'flex';
          this.innerHTML = '▲';
          this.style.background = 'rgba(27, 209, 254, 0.2)';
        } else {
          links.style.display = 'none';
          this.innerHTML = '▼';
          this.style.background = 'rgba(0, 0, 0, 0.8)';
        }
        e.stopPropagation();
      });
      document.addEventListener('click', function(e) {
        const links = document.getElementById('footer-menu-links');
        const toggle = document.getElementById('footer-menu-toggle');
        if (links && links.style.display === 'flex' && !document.getElementById('footer-menu-container').contains(e.target)) {
          links.style.display = 'none';
          toggle.innerHTML = '▼';
          toggle.style.background = 'rgba(0, 0, 0, 0.8)';
