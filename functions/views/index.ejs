<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="pragma" content="no-cache">
    <meta http-equiv="cache-control" content="no-cache">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <title>Arknights 抽卡紀錄</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <!-- 載入你的 CSS -->
    <link rel="stylesheet" href="/css/your.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      .collapsible-content {
        display: none;
      }
      .collapsible-content.open {
        display: block;
      }
      .tshJ_L {
        cursor: pointer;
      }
      /* Dashboard styles */
      .dashboard-panel {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        padding: 1.5rem;
        background: #121212;
        border-radius: 0.5rem;
        margin: 1rem;
        color: #fff;
        font-family: 'cwTeXHeiBold', 'Heiti TC', sans-serif;
      }
      .dashboard-card {
        flex: 1;
        min-width: 300px;
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .dashboard-card h3 {
        margin-top: 0;
        color: #10d1fe;
        font-size: 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding-bottom: 0.5rem;
      }
      .dashboard-card p {
        font-size: 1.1rem;
        line-height: 1.6;
        margin: 0.8rem 0;
      }
      .dashboard-card .highlight-number {
        font-size: 1.3rem;
        color: #f7ff00;
        font-weight: bold;
      }
      
      .charts-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        justify-content: center;
        align-items: flex-end;
        padding: 1.5rem;
        margin: 1rem;
        background: #121212;
        border-radius: 0.5rem;
      }
      .chart-box {
        width: 250px;
        text-align: center;
      }
      .chart-box h4 {
        color: #fff;
        margin-bottom: 1rem;
        font-size: 1.1rem;
        font-weight: normal;
      }
    </style>
  </head>
  <body class="dark-mode" style="background-color: #000000; color: #e0e0e0">
    <!-- 上方遮攔區塊 -->
    <div class="n9kTOc">
      <div class="zpp1t9">
        <div class="uUPDec">
          <div class="Uqsjld">
            <div class="MvFHTi">
              <div>
                <a href="/export" download style="display: block; width: 100%; height: 100%; color: inherit; text-decoration: none;">
                  導出結果
                </a>
                <div class="kR9c6i"></div>
              </div>
              <div>
                <a href="/logout" style="display: block; width: 100%; height: 100%; color: inherit; text-decoration: none;">
                  登出
                </a>
                <div class="kR9c6i"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="HgfD8Q">
          <div class="tshJ_L"><%= nickname %> 的尋訪紀錄</div>
        </div>
      </div>
      <div class="MMIY1i">
        <div class="uYZr59"></div>
        <div class="g2xLrB"></div>
      </div>
    </div>
    <div class="RNJ708 pt2fh0"></div>

    <!-- 統計資訊：星級分佈（可折疊，預設展開） -->
    <div class="HgfD8Q">
      <div class="tshJ_L">統計資訊 ▲</div>
      <div class="collapsible-content open">
        <div class="KXADwl">
          <div class="Ysu7ON"></div>
          <span></span><span></span>
        </div>
        
        <!-- highlight顯示區 改用 HTML + CSS -->
        <div class="dashboard-panel">
            <% 
              let lastCounts = stats.starcountsPool[stats.lastPullId] || { '5': 0, '4': 0, '3': 0, '2': 0 };
              let lastTotal = lastCounts['5'] + lastCounts['4'] + lastCounts['3'] + lastCounts['2'];
              let allCounts = stats.starcounts['所有卡池'];
              let allTotal = allCounts['5'] + allCounts['4'] + allCounts['3'] + allCounts['2'];
              let allCost = stats.totalPulls * 600;
              let avgPulls = allCounts['5'] > 0 ? (stats.totalPulls / allCounts['5']).toFixed(2) : 0;
              let avgCost = allCounts['5'] > 0 ? (allCost / allCounts['5']).toFixed(2) : 0;
            %>
            <div class="dashboard-card">
                <h3>當前卡池狀態</h3>
                <p>您最後一次抽取的卡池為：<br/><span style="color: #fff; font-size: 1.3rem;"><%= stats.lastPullName %></span></p>
                <p>在該卡池中您一共投入了 <span class="highlight-number"><%= lastTotal %></span> 抽，距離上次六星已經墊了 <span class="highlight-number"><%= stats.accumulation %></span> 抽</p>
                <p>其中有 <span style="color: #f7ff00"><%= lastCounts['5'] %></span> 次 6 星，<span style="color: #cc7a00"><%= lastCounts['4'] %></span> 次 5 星，<br/>
                <span style="color: #a231ff"><%= lastCounts['3'] %></span> 次 4 星，<span style="color: #19d1ff"><%= lastCounts['2'] %></span> 次 3 星</p>
            </div>
            
            <div class="dashboard-card">
                <h3>總覽資料</h3>
                <p>在所有紀錄中您一共投入了 <span class="highlight-number"><%= allTotal %></span> 抽<br/>共消耗 <span class="highlight-number"><%= allCost %></span> 合成玉</p>
                <p>其中有 <span style="color: #f7ff00"><%= allCounts['5'] %></span> 次 6 星，<span style="color: #cc7a00"><%= allCounts['4'] %></span> 次 5 星，<br/>
                <span style="color: #a231ff"><%= allCounts['3'] %></span> 次 4 星，<span style="color: #19d1ff"><%= allCounts['2'] %></span> 次 3 星</p>
                <p>您的平均出金抽數為 <span class="highlight-number"><%= avgPulls %></span> 抽<br/>折合 <span class="highlight-number"><%= avgCost %></span> 合成玉</p>
            </div>
        </div>

        <!-- 圓餅圖顯示區 -->
        <h2 style="text-align: center; color: #fff; margin-top: 2rem;">星級分佈</h2>
        <div class="charts-container">
            <% const categories = ['所有卡池', '限定尋訪', '標準尋訪', '中堅尋訪', '其他尋訪']; %>
            <% categories.forEach(function(cat, index) { 
                let c = stats.starcounts[cat] || { '5': 0, '4': 0, '3': 0, '2': 0 };
                let total = c['5'] + c['4'] + c['3'] + c['2'];
                let titleHtml;
                if (cat === '標準尋訪' || cat === '中堅尋訪') {
                    let subcount = stats.countAcc[cat] || 0;
                    titleHtml = cat + `（總計${total}抽）<br><span style="font-size: 0.9em; color: #ccc;">（已墊 ${subcount} 抽）</span>`;
                } else {
                    titleHtml = cat + `（總計${total}抽）<br><span style="font-size: 0.9em;">&nbsp;</span>`;
                }
            %>
            <div class="chart-box">
                <h4 style="margin-bottom: 0.5rem; line-height: 1.4; padding-right: 35px;"><%- titleHtml %></h4>
                <% if(total > 0) { %>
                    <canvas id="chart-pie-<%= index %>" width="250" height="250"></canvas>
                <% } else { %>
                    <div style="width: 250px; height: 250px; line-height: 250px; color: #888; font-size: 1.2rem;">無資料</div>
                <% } %>
            </div>
            <% }); %>
        </div>

        <!-- 注意事項 -->
        <div class="x82bAA">
          <div class="tshJ_L">注意事項</div>
          <div class="ab1yWq">
            <div class="wYL2n2 Q25EOd"></div>
            <div class="wYL2n2 xW0Sk9"></div>
            <div class="wYL2n2 m8kOmo"></div>
            <div class="wYL2n2 Mric6f"></div>
            <div class="Xo6v7v">
              <div>1：限定尋訪包含：春節、慶典（週年）、夏季、連動，以上卡池之間保底不互通。</div>
              <div>2：標準尋訪包含：定向尋訪（單人輪換）、標準尋訪（雙人輪換）、定向選調（單UP）、標準選調（雙UP）、選調復刻、<br />
                &emsp;&emsp;聯合行動、前路回響、定向甄選，以上卡池之間保底互通。</div>
              <div>3：中堅尋訪包含：中堅尋訪（輪換）、中堅甄選，以上卡池之間保底互通。</div>
              <div>4：其他尋訪包含：跨年歡慶、跨年歡慶．中堅、新人特惠、剩餘未列出卡池（理應沒有），以上卡池之間保底不互通。</div>
            </div>
          </div>
          <div class="KXADwl">
            <div class="Ysu7ON"></div>
            <span></span><span></span>
          </div>
          <div class="ab1yWq">
            <div class="wYL2n2 Q25EOd"></div>
            <div class="wYL2n2 xW0Sk9"></div>
            <div class="wYL2n2 m8kOmo"></div>
            <div class="wYL2n2 Mric6f"></div>
            <div class="Xo6v7v">
              <div>5：抽數的計算規則：標準尋訪與中堅尋訪將繼承保底進度累計計算，其餘尋訪依卡池分開計算。</div>
              <div>6：抓取結果理論上與官網查詢結果一致，可能與遊戲內實際操作存在延遲。</div>
              <div>7：如果官方的紀錄中有出現卡池欄位為空白的情況，這裡會顯示卡池ID並標注名稱未顯示。</div>
              <div>8：如果抓取紀錄與官網紀錄存在差異，可重新抓取，若無法解決，可聯繫網站作者或逕行修改json檔案。</div>
              <div>9：如果官網紀錄與遊戲內實際操作存在差異，請直接聯繫官方客服。</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 近期出金：僅顯示 5 星角色（可折疊，預設展開） -->
    <div class="HgfD8Q">
      <div class="tshJ_L">近期出金 ▲</div>
      <div class="collapsible-content open">
        <div class="KXADwl">
          <div class="Ysu7ON"></div>
          <span></span><span></span>
        </div>
        <div class="mzlLY0">
          <div class="pvfQQe">
            <div class="_P1qVa">獲得幹員（抽數）</div>
            <div class="Zs7Y7r">尋訪卡池</div>
            <div class="GETong">尋訪時間</div>
          </div>
          <div class="EkxzYd">
            <% const starClasses = { '5': 'UN5Fou', '4': 'A0qObD', '3': 'spIT3K', '2': 'Ff2rvO' }; %>
            <% 
               let recentGroups = [];
               let currentRecentGroup = null;
               logs.filter(item => String(item.rarity) === '5').forEach(item => {
                   let currentPool = item.poolName || `${item.poolId}（名稱未顯示）`;
                   if (!currentRecentGroup || currentRecentGroup.pool !== currentPool) {
                       currentRecentGroup = { pool: currentPool, items: [] };
                       recentGroups.push(currentRecentGroup);
                   }
                   currentRecentGroup.items.push(item);
               });
               
               recentGroups.forEach(function(group) { 
            %>
            <div class="tshJ_L" style="background: rgba(255,255,255,0.05); margin: 6px 0 2px 0; height: 2rem; padding: 2px 15px; font-size: 0.95rem; line-height: 1.5; color: #10d1fe; border-radius: 4px; border-left: 4px solid #10d1fe;"><%= group.pool %> ▲</div>
            <div class="collapsible-content open" style="margin-bottom: 0.5rem;">
              <% group.items.forEach(function(item) { 
                 let sc = starClasses[item.rarity] || 'spIT3K';
              %>
            <div class="gX_vOH">
              <div class="oX8Bos">
                <div class="h1yWiG"><%= item.charName %></div>
                <div class="feiJCc"><%= item.time %></div>
              </div>
              <div class="ORrqqm">
                <div class="qcP3VO">
                  <% if (item.isNew) { %>
                  <div class="QnXVrG">NEW</div>
                  <% } %>
                  <img
                    class="<%= sc %>"
                    src="https://ak-tw.hg-cdn.com/arknights/game/assets/char/avatar/<%= item.charId %>.png"
                    alt="<%= item.charName %>"
                  />
                  <div class="NgcapS">
                    <%= item.charName %><% if (item.interval !== undefined && item.interval !== null) { %>（<%= item.interval %>）<% } %>
                  </div>
                  <div class="rT1IyY <%= sc %>"></div>
                </div>
              </div>
              <div class="xWZ6Cb">
                <%= item.poolName %><% if (!item.poolName) { %><%= item.poolId %>（名稱未顯示）<% } %>
              </div>
              <div class="r9iEWS"><%= item.time %></div>
            </div>
              <% }); %>
            </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>

    <!-- 尋訪記錄：顯示所有角色（可折疊，預設展開） -->
    <div class="HgfD8Q">
      <div class="tshJ_L">尋訪記錄 ▲</div>
      <div class="collapsible-content open">
        <div class="KXADwl">
          <div class="Ysu7ON"></div>
          <span></span><span></span>
        </div>
        <div class="mzlLY0">
          <div class="pvfQQe">
            <div class="_P1qVa">獲得幹員</div>
            <div class="Zs7Y7r">尋訪卡池</div>
            <div class="GETong">尋訪時間</div>
          </div>
          <div class="EkxzYd">
            <% 
               let allGroups = [];
               let currentAllGroup = null;
               logs.forEach(item => {
                   let currentPool = item.poolName || `${item.poolId}（名稱未顯示）`;
                   if (!currentAllGroup || currentAllGroup.pool !== currentPool) {
                       currentAllGroup = { pool: currentPool, items: [] };
                       allGroups.push(currentAllGroup);
                   }
                   currentAllGroup.items.push(item);
               });
               
               allGroups.forEach(function(group) { 
            %>
            <div class="tshJ_L" style="background: rgba(255,255,255,0.05); margin: 6px 0 2px 0; height: 2rem; padding: 2px 15px; font-size: 0.95rem; line-height: 1.5; color: #f7ff00; border-radius: 4px; border-left: 4px solid #f7ff00;"><%= group.pool %> ▲</div>
            <div class="collapsible-content open" style="margin-bottom: 0.5rem;">
              <% group.items.forEach(function(item) { 
                 let sc = starClasses[item.rarity] || 'spIT3K';
              %>
            <div class="gX_vOH">
              <div class="oX8Bos">
                <div class="h1yWiG"><%= item.charName %></div>
                <div class="feiJCc"><%= item.time %></div>
              </div>
              <div class="ORrqqm">
                <div class="qcP3VO">
                  <% if (item.isNew) { %>
                  <div class="QnXVrG">NEW</div>
                  <% } %>
                  <img
                    class="<%= sc %>"
                    src="https://ak-tw.hg-cdn.com/arknights/game/assets/char/avatar/<%= item.charId %>.png"
                    alt="<%= item.charName %>"
                  />
                  <div class="NgcapS"><%= item.charName %></div>
                  <div class="rT1IyY <%= sc %>"></div>
                </div>
              </div>
              <div class="xWZ6Cb">
                <%= item.poolName %><% if (!item.poolName) { %><%= item.poolId %>（名稱未顯示）<% } %>
              </div>
              <div class="r9iEWS"><%= item.time %></div>
            </div>
              <% }); %>
            </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>

    <script>
      // Accordion effect
      document.querySelectorAll(".tshJ_L").forEach((header) => {
        header.addEventListener("click", () => {
          const content = header.nextElementSibling;
          if (content && content.classList.contains('collapsible-content')) {
            content.classList.toggle("open");
            header.textContent = header.textContent.endsWith("▼")
              ? header.textContent.replace("▼", "▲")
              : header.textContent.replace("▲", "▼");
          }
        });
      });

      // Render Chart.js
      Chart.defaults.color = '#fff';
      Chart.defaults.font.family = "'cwTeXHeiBold', 'Heiti TC', sans-serif";
      
      const chartColors = ['#f7ff00', '#cc7a00', '#a231ff', '#19d1ff'];
      const chartLabels = ['6星', '5星', '4星', '3星'];
      
      const starcountsData = <%- JSON.stringify(stats.starcounts) %>;
      const categories = ['所有卡池', '限定尋訪', '標準尋訪', '中堅尋訪', '其他尋訪'];
      
      categories.forEach((cat, index) => {
          let c = starcountsData[cat];
          if(c && (c['5'] + c['4'] + c['3'] + c['2'] > 0)) {
              let ctx = document.getElementById('chart-pie-' + index);
              if (ctx) {
                  new Chart(ctx, {
                      type: 'pie',
                      data: {
                          labels: chartLabels,
                          datasets: [{
                              data: [c['5'], c['4'], c['3'], c['2']],
                              backgroundColor: chartColors,
                              hoverOffset: 4,
                              borderWidth: 0
                          }]
                      },
                      options: {
                          responsive: false,
                          plugins: {
                              legend: {
                                  position: 'right',
                                  labels: { color: '#fff' }
                              },
                              tooltip: {
                                  callbacks: {
                                      label: function(context) {
                                          let label = context.label || '';
                                          if (label) { label += ': '; }
                                          if (context.parsed !== null) {
                                              let total = context.dataset.data.reduce((a, b) => a + b, 0);
                                              let percent = ((context.parsed / total) * 100).toFixed(1) + '%';
                                              label += context.parsed + ' (' + percent + ')';
                                          }
                                          return label;
                                      }
                                  }
                              }
                          }
                      }
                  });
              }
          }
      });
    </script>
  </body>
</html>
