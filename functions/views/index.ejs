<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
    <meta http-equiv="pragma" content="no-cache">
    <meta http-equiv="cache-control" content="no-cache">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <title>Arknights 抽卡紀錄</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <!-- 載入你的 CSS -->
    <link rel="stylesheet" href="/css/your.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      .collapsible-content {
        display: none;
      }
      .collapsible-content.open {
        display: block;
      }
      .tshJ_L {
        cursor: pointer;
      }
      /* Dashboard styles */
      .dashboard-panel {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        padding: 1.5rem;
        background: #121212;
        border-radius: 0.5rem;
        margin: 1rem;
        color: #fff;
        font-family: 'cwTeXHeiBold', 'Heiti TC', sans-serif;
      }
      .dashboard-card {
        flex: 1;
        min-width: 300px;
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .dashboard-card h3 {
        margin-top: 0;
        color: #10d1fe;
        font-size: 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding-bottom: 0.5rem;
      }
      .dashboard-card p {
        font-size: 1.1rem;
        line-height: 1.6;
        margin: 0.8rem 0;
      }
      .dashboard-card .highlight-number {
        font-size: 1.3rem;
        color: #f7ff00;
        font-weight: bold;
      }
      
      .charts-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        justify-content: center;
        align-items: flex-end;
        padding: 1.5rem;
        margin: 1rem;
        background: #121212;
        border-radius: 0.5rem;
      }
      .chart-box {
        width: 250px;
        text-align: center;
      }
      .chart-box h4 {
        color: #fff;
        margin-bottom: 1rem;
        font-size: 1.1rem;
        font-weight: normal;
      }
    </style>
  </head>
  <body class="dark-mode" style="background-color: #000000; color: #e0e0e0">
    
    <!-- <div class="wQb8hv"> -->

      <!-- 上方遮攔區塊 -->
      <div class="n9kTOc">
        
        <div class="zpp1t9">
          <div class="uUPDec">
            <div class="Uqsjld">
              <div class="MvFHTi">
                <div>
                  <a href="/export" download style="display: block; width: 100%; height: 100%; color: inherit; text-decoration: none;">
                    導出結果
                  </a>
                  <div class="kR9c6i"></div>
                </div>
                <div>
                  <a href="/logout" style="display: block; width: 100%; height: 100%; color: inherit; text-decoration: none;">
                    登出
                  </a>
                  <div class="kR9c6i"></div>
                </div>
              </div>
            </div>
          </div>
          <div class="HgfD8Q">
            <div class="tshJ_L"><%= nickname %> 的尋訪紀錄</div>
          </div>
        </div>
        <div class="MMIY1i">
          <div class="uYZr59"></div>
          <!-- <div class="g2xLrB"></div> -->
        </div>
      </div>

      <div class="RHyFR2">
        <!-- 側邊欄 -->
        <div class="CAmS7u">
          <div class="uLuxH3">
            <img src="data:image/png;base64,">
            <div class="WetgH2">
              <div></div>
              <span>POOL SELECTOR<br>（不影響統計資訊）</span>
            </div>
          </div>
          <div class="nEG21w" style="overflow-y: auto;">
            <div style="padding: 1rem; color: #fff;">
              <div style="margin-bottom: 1rem; border-bottom: 1px solid #333; padding-bottom: 0.5rem; display: flex; align-items: flex-start;">
                <input type="checkbox" id="filter-pool-all" checked style="margin-top: 3px; cursor: pointer;" />
                <label for="filter-pool-all" style="margin-left: 0.5rem; font-size: 0.95rem; font-weight: bold; cursor: pointer; user-select: none; line-height: 1.3;">全選 / 全取消</label>
              </div>
              <% 
                let uniquePoolsMap = new Map();
                logs.forEach(log => {
                  let pName = log.poolName || `${log.poolId}（名稱未顯示）`;
                  if (!uniquePoolsMap.has(log.poolId)) {
                    uniquePoolsMap.set(log.poolId, pName);
                  }
                });
                let uniquePools = Array.from(uniquePoolsMap.entries());
                uniquePools.forEach(([pId, pName], i) => { 
              %>
                <div style="margin-bottom: 0.8rem; display: flex; align-items: flex-start;">
                  <input type="checkbox" id="filter-pool-<%= i %>" class="pool-filter-cb" value="<%= pId %>" checked style="margin-top: 3px; cursor: pointer;" />
                  <label for="filter-pool-<%= i %>" style="margin-left: 0.5rem; font-size: 0.85rem; cursor: pointer; user-select: none; line-height: 1.3;"><%= pName %></label>
                </div>
              <% }); %>
            </div>

            <!-- Sidebar Footer Buttons (Moved inside nEG21w) -->
            <div style="padding: 0 1rem 2rem 1rem; border-top: 1px solid #333; margin-top: 1rem; padding-top: 1.5rem;">
              <a href="/export" download style="display: block; width: 100%; padding: 0.8rem; text-align: center; background: rgba(255,255,255,0.1); color: #fff; text-decoration: none; border-radius: 4px; margin-bottom: 0.8rem; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">導出結果</a>
              <a href="/logout" style="display: block; width: 100%; padding: 0.8rem; text-align: center; background: rgba(27,209,254,0.2); color: #1bd1fe; text-decoration: none; border-radius: 4px; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.3)'" onmouseout="this.style.background='rgba(27,209,254,0.2)'">登出</a>
            </div>
          </div>
        </div>
        <!-- 主畫面 -->
        <div class="RNJ708 pt2fh0"></div>

        <div class="oFCHMT">

          <!-- 一個 20vh 的空白 -->
          <div style="height: 20vh;"></div>

          <!-- 統計資訊：星級分佈（可折疊，預設展開） -->
          <div class="HgfD8Q">
            <div class="tshJ_L">統計資訊 ▲</div>
            <div class="collapsible-content open">
              <div class="KXADwl">
                <div class="Ysu7ON"></div>
                <span></span><span></span>
              </div>
              
              <!-- highlight顯示區 改用 HTML + CSS -->
              <div class="dashboard-panel">
                  <% 
                    let earliestDate = logs.length > 0 ? logs.reduce((min, p) => p.time < min ? p.time : min, logs[0].time).split(' ')[0] : '近期';
                    let lastCounts = stats.starcountsPool[stats.lastPullId] || { '5': 0, '4': 0, '3': 0, '2': 0 };
                    let lastTotal = lastCounts['5'] + lastCounts['4'] + lastCounts['3'] + lastCounts['2'];
                    let allCounts = stats.starcounts['所有卡池'];
                    let allTotal = allCounts['5'] + allCounts['4'] + allCounts['3'] + allCounts['2'];
                    let allCost = stats.totalPulls * 600;
                    let avgPulls = allCounts['5'] > 0 ? (stats.totalPulls / allCounts['5']).toFixed(2) : 0;
                    let avgCost = allCounts['5'] > 0 ? (allCost / allCounts['5']).toFixed(2) : 0;
                  %>
                  <div class="dashboard-card">
                      <h3>當前卡池狀態</h3>
                      <p>您最後一次抽取的卡池為：<br/><span style="color: #fff; font-size: 1.3rem;"><%= stats.lastPullName %></span></p>
                      <p>在該卡池中您一共投入了 <span class="highlight-number"><%= lastTotal %></span> 抽，距離上次六星已經墊了 <span class="highlight-number"><%= stats.accumulation %></span> 抽</p>
                      <p>其中有 <span style="color: #f7ff00"><%= lastCounts['5'] %></span> 次 6 星 (<%= lastTotal > 0 ? (lastCounts['5']/lastTotal*100).toFixed(1) : 0 %>%)，<span style="color: #cc7a00"><%= lastCounts['4'] %></span> 次 5 星 (<%= lastTotal > 0 ? (lastCounts['4']/lastTotal*100).toFixed(1) : 0 %>%)，<br/>
                      <span style="color: #a231ff"><%= lastCounts['3'] %></span> 次 4 星 (<%= lastTotal > 0 ? (lastCounts['3']/lastTotal*100).toFixed(1) : 0 %>%)，<span style="color: #19d1ff"><%= lastCounts['2'] %></span> 次 3 星 (<%= lastTotal > 0 ? (lastCounts['2']/lastTotal*100).toFixed(1) : 0 %>%)</p>
                  </div>
                  
                  <div class="dashboard-card">
                      <h3>總覽資料</h3>
                      <p>自 <span style="color: #10d1fe"><%= earliestDate %></span> 起，您一共投入了 <span class="highlight-number"><%= allTotal %></span> 抽<br/>共消耗 <span class="highlight-number" style="color: #C63A5A"><%= allCost %></span> 合成玉</p>
                      <p>其中有 <span style="color: #f7ff00"><%= allCounts['5'] %></span> 次 6 星 (<%= allTotal > 0 ? (allCounts['5']/allTotal*100).toFixed(1) : 0 %>%)，<span style="color: #cc7a00"><%= allCounts['4'] %></span> 次 5 星 (<%= allTotal > 0 ? (allCounts['4']/allTotal*100).toFixed(1) : 0 %>%)，<br/>
                      <span style="color: #a231ff"><%= allCounts['3'] %></span> 次 4 星 (<%= allTotal > 0 ? (allCounts['3']/allTotal*100).toFixed(1) : 0 %>%)，<span style="color: #19d1ff"><%= allCounts['2'] %></span> 次 3 星 (<%= allTotal > 0 ? (allCounts['2']/allTotal*100).toFixed(1) : 0 %>%)</p>
                      <p>您的平均出金抽數為 <span class="highlight-number"><%= avgPulls %></span> 抽<br/>折合 <span class="highlight-number" style="color: #C63A5A"><%= avgCost %></span> 合成玉</p>
                  </div>
              </div>

              <!-- 圓餅圖顯示區 -->
              <h2 style="text-align: center; color: #fff; margin-top: 2rem;">星級分佈</h2>
              <div class="charts-container">
                  <!-- const categories = ['所有卡池', '限定尋訪', '標準尋訪', '中堅尋訪', '其他尋訪']; -->
                  <% const categories = ['限定尋訪', '標準尋訪', '中堅尋訪', '其他尋訪']; %>
                  <% categories.forEach(function(cat, index) { 
                      let c = stats.starcounts[cat] || { '5': 0, '4': 0, '3': 0, '2': 0 };
                      let total = c['5'] + c['4'] + c['3'] + c['2'];
                      let titleHtml;
                      if (cat === '標準尋訪' || cat === '中堅尋訪') {
                          let subcount = stats.countAcc[cat] || 0;
                          titleHtml = cat + `（總計${total}抽）<br><span style="font-size: 0.9em; color: #ccc;">（已墊 ${subcount} 抽）</span>`;
                      } else {
                          titleHtml = cat + `（總計${total}抽）<br><span style="font-size: 0.9em;">&nbsp;</span>`;
                      }
                  %>
                  <div class="chart-box">
                      <h4 style="margin-bottom: 0.5rem; line-height: 1.4; padding-right: 50px;"><%- titleHtml %></h4>
                      <% if(total > 0) { %>
                          <canvas id="chart-pie-<%= index %>" width="250" height="250"></canvas>
                      <% } else { %>
                          <div style="width: 250px; height: 250px; line-height: 250px; color: #888; font-size: 1.2rem;">無資料</div>
                      <% } %>
                  </div>
                  <% }); %>
              </div>

              <!-- 注意事項 -->
              <div class="x82bAA">
                <div class="tshJ_L">注意事項</div>
                <div class="ab1yWq">
                  <div class="wYL2n2 Q25EOd"></div>
                  <div class="wYL2n2 xW0Sk9"></div>
                  <div class="wYL2n2 m8kOmo"></div>
                  <div class="wYL2n2 Mric6f"></div>
                  <div class="Xo6v7v">
                    <div>1：限定尋訪包含：春節、慶典（週年）、夏季、連動，以上卡池之間保底不互通。</div>
                    <div>2：標準尋訪包含：定向尋訪（單人輪換）、標準尋訪（雙人輪換）、定向選調（單UP）、標準選調（雙UP）、選調復刻、<br />
                      &emsp;&emsp;聯合行動、前路回響、定向甄選，以上卡池之間保底互通。</div>
                    <div>3：中堅尋訪包含：中堅尋訪（輪換）、中堅甄選，以上卡池之間保底互通。</div>
                    <div>4：其他尋訪包含：跨年歡慶、跨年歡慶．中堅、新人特惠、剩餘未列出卡池（理應沒有），以上卡池之間保底不互通。</div>
                  </div>
                </div>
                <div class="KXADwl">
                  <div class="Ysu7ON"></div>
                  <span></span><span></span>
                </div>
                <div class="ab1yWq">
                  <div class="wYL2n2 Q25EOd"></div>
                  <div class="wYL2n2 xW0Sk9"></div>
                  <div class="wYL2n2 m8kOmo"></div>
                  <div class="wYL2n2 Mric6f"></div>
                  <div class="Xo6v7v">
                    <div>5：抽數的計算規則：標準尋訪與中堅尋訪將繼承保底進度累計計算，其餘尋訪依卡池分開計算。</div>
                    <div>6：抓取結果理論上與官網查詢結果一致，可能與遊戲內實際操作存在延遲。</div>
                    <div>7：如果官方的紀錄中有出現卡池欄位為空白的情況，這裡會顯示卡池ID並標注名稱未顯示。</div>
                    <div>8：如果抓取紀錄與官網紀錄存在差異，可重新抓取，若無法解決，可聯繫網站作者或逕行修改json檔案。</div>
                    <div>9：如果官網紀錄與遊戲內實際操作存在差異，請直接聯繫官方客服。</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- 近期出金（可折疊，預設展開） -->
          <div class="HgfD8Q">
            <div class="tshJ_L">近期出金 ▲</div>
            <div class="collapsible-content open">
              <div class="KXADwl">
                <div class="Ysu7ON"></div>
                <span></span><span></span>
              </div>
              <div style="display: flex; justify-content: flex-start; margin-bottom: 0.5rem; padding-left: 13.5rem;">
                 <span style="font-size: 0.9rem; color: #10d1fe; cursor: pointer; user-select: none; font-weight: bold;" onclick="toggleAllGroups('recent')">[ 全部摺疊 / 展開 ]</span>
              </div>
              <div class="mzlLY0">
                <div class="pvfQQe">
                  <div class="_P1qVa">獲得幹員（抽數）</div>
                  <div class="Zs7Y7r">尋訪卡池</div>
                  <div class="GETong">尋訪時間</div>
                </div>
                
                <div class="EkxzYd" id="recent-container">
                  <% const starClasses = { '5': 'UN5Fou', '4': 'A0qObD', '3': 'spIT3K', '2': 'Ff2rvO' }; %>
                  <% 
                    let recentGroups = [];
                    let currentRecentGroup = null;
                    logs.filter(item => String(item.rarity) === '5').forEach(item => {
                        let currentPoolName = item.poolName || `${item.poolId}（名稱未顯示）`;
                        let currentPoolId = item.poolId;
                        if (!currentRecentGroup || currentRecentGroup.poolId !== currentPoolId) {
                            currentRecentGroup = { poolName: currentPoolName, poolId: currentPoolId, items: [] };
                            recentGroups.push(currentRecentGroup);
                        }
                        currentRecentGroup.items.push(item);
                    });
                    
                    recentGroups.forEach(function(group) { 
                      let pStats = stats.starcountsPool[group.poolId] || { '5': 0, '4': 0, '3': 0, '2': 0 };
                      let pTotal = pStats['5'] + pStats['4'] + pStats['3'] + pStats['2'];
                  %>
                  <div class="pool-group-wrapper" data-pool="<%= group.poolId %>">
                    <div class="tshJ_L" style="background: rgba(255,255,255,0.05); margin: 6px 0 6px 0; height: 2rem; padding: 4px 15px; font-size: 1rem; line-height: 1.5; color: #10d1fe; border-radius: 4px; border-left: 4px solid #10d1fe;"><%= group.poolName %>（<%= pTotal %>抽） ▲</div>
                    <div class="collapsible-content open" style="margin-bottom: 0.5rem;">
                      <% group.items.forEach(function(item) { 
                        let sc = starClasses[item.rarity] || 'spIT3K';
                      %>
                    <div class="gX_vOH">
                      <div class="oX8Bos">
                        <div class="h1yWiG"><%= item.charName %></div>
                        <div class="feiJCc"><%= item.time %></div>
                      </div>
                      <div class="ORrqqm">
                        <div class="qcP3VO">
                          <% if (item.isNew) { %>
                          <div class="QnXVrG">NEW</div>
                          <% } %>
                          <img
                            class="<%= sc %>"
                            src="https://ak-tw.hg-cdn.com/arknights/game/assets/char/avatar/<%= item.charId %>.png"
                            alt="<%= item.charName %>"
                          />
                          <div class="NgcapS">
                            <%= item.charName %><% if (item.interval !== undefined && item.interval !== null) { %>（<%= item.interval %>）<% } %>
                          </div>
                          <div class="rT1IyY <%= sc %>"></div>
                        </div>
                      </div>
                      <div class="xWZ6Cb">
                        <%= item.poolName %><% if (!item.poolName) { %><%= item.poolId %>（名稱未顯示）<% } %>
                      </div>
                      <div class="r9iEWS"><%= item.time %></div>
                    </div>
                      <% }); %>
                    </div>
                  </div>
                  <% }); %>
                </div>
              </div>
            </div>
          </div>

          <!-- 尋訪記錄：顯示所有角色（可折疊，預設展開） -->
          <div class="HgfD8Q">
            <div class="tshJ_L">尋訪記錄 ▲</div>
            <div class="collapsible-content open">
              <div class="KXADwl">
                <div class="Ysu7ON"></div>
                <span></span><span></span>
              </div>
              <div style="display: flex; justify-content: flex-start; margin-bottom: 0.5rem; padding-left: 13.5rem;">
                 <span style="font-size: 0.9rem; color: #f7ff00; cursor: pointer; user-select: none; font-weight: bold;" onclick="toggleAllGroups('history')">[ 全部摺疊 / 展開 ]</span>
              </div>
              <div class="mzlLY0">
                <div class="pvfQQe">
                  <div class="_P1qVa">獲得幹員</div>
                  <div class="Zs7Y7r">尋訪卡池</div>
                  <div class="GETong">尋訪時間</div>
                </div>
                <div class="EkxzYd" id="history-container">
                  <% 
                    let allGroups = [];
                    let currentAllGroup = null;
                    logs.forEach(item => {
                        let currentPoolName = item.poolName || `${item.poolId}（名稱未顯示）`;
                        let currentPoolId = item.poolId;
                        if (!currentAllGroup || currentAllGroup.poolId !== currentPoolId) {
                            currentAllGroup = { poolName: currentPoolName, poolId: currentPoolId, items: [] };
                            allGroups.push(currentAllGroup);
                        }
                        currentAllGroup.items.push(item);
                    });
                    
                    allGroups.forEach(function(group) { 
                      let pStats = stats.starcountsPool[group.poolId] || { '5': 0, '4': 0, '3': 0, '2': 0 };
                      let pTotal = pStats['5'] + pStats['4'] + pStats['3'] + pStats['2'];
                  %>
                  <div class="pool-group-wrapper" data-pool="<%= group.poolId %>">
                    <div class="tshJ_L" style="background: rgba(255,255,255,0.05); margin: 6px 0 2px 0; height: 2rem; padding: 4px 15px; font-size: 1rem; line-height: 1.5; color: #f7ff00; border-radius: 4px; border-left: 4px solid #f7ff00;"><%= group.poolName %>（<%= pTotal %>抽） ▲</div>
                    <div class="collapsible-content open" style="margin-bottom: 0.5rem;">
                      <% group.items.forEach(function(item) { 
                        let sc = starClasses[item.rarity] || 'spIT3K';
                      %>
                    <div class="gX_vOH">
                      <div class="oX8Bos">
                        <div class="h1yWiG"><%= item.charName %></div>
                        <div class="feiJCc"><%= item.time %></div>
                      </div>
                      <div class="ORrqqm">
                        <div class="qcP3VO">
                          <% if (item.isNew) { %>
                          <div class="QnXVrG">NEW</div>
                          <% } %>
                          <img
                            class="<%= sc %>"
                            src="https://ak-tw.hg-cdn.com/arknights/game/assets/char/avatar/<%= item.charId %>.png"
                            alt="<%= item.charName %>"
                          />
                          <div class="NgcapS"><%= item.charName %></div>
                          <div class="rT1IyY <%= sc %>"></div>
                        </div>
                      </div>
                      <div class="xWZ6Cb">
                        <%= item.poolName %><% if (!item.poolName) { %><%= item.poolId %>（名稱未顯示）<% } %>
                      </div>
                      <div class="r9iEWS"><%= item.time %></div>
                    </div>
                      <% }); %>
                    </div>
                  </div>
                  <% }); %>
                </div>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    <!-- </div> -->
    <script>
      // Mobile sidebar toggle
      const mobileBtn = document.querySelector('.uYZr59');
      const sidebar = document.querySelector('.CAmS7u');
      if (mobileBtn && sidebar) {
        mobileBtn.addEventListener('click', () => {
          mobileBtn.classList.toggle('OH5OMA');
          sidebar.classList.toggle('bWI6VY');
        });
      }

      // Accordion effect
      document.querySelectorAll(".tshJ_L").forEach((header) => {
        header.addEventListener("click", () => {
          const content = header.nextElementSibling;
          if (content && content.classList.contains('collapsible-content')) {
            content.classList.toggle("open");
            header.innerHTML = header.innerHTML.endsWith("▼")
              ? header.innerHTML.replace("▼", "▲")
              : header.innerHTML.replace("▲", "▼");
          }
        });
      });

      // Toggle all groups
      function toggleAllGroups(type) {
        const container = document.getElementById(type + '-container');
        if (!container) return;
        
        const headers = container.querySelectorAll('.pool-group-wrapper > .tshJ_L');
        let anyOpen = false;
        
        headers.forEach(h => {
          const content = h.nextElementSibling;
          if (content && content.classList.contains('open')) {
            anyOpen = true;
          }
        });
        
        headers.forEach(h => {
          const content = h.nextElementSibling;
          if (!content) return;
          
          if (anyOpen) {
             // Close all
             if (content.classList.contains('open')) {
               content.classList.remove('open');
               h.innerHTML = h.innerHTML.replace('▲', '▼');
             }
          } else {
             // Open all
             if (!content.classList.contains('open')) {
               content.classList.add('open');
               h.innerHTML = h.innerHTML.replace('▼', '▲');
             }
          }
        });
      }

      // Render Chart.js
      Chart.defaults.color = '#fff';
      Chart.defaults.font.family = "'cwTeXHeiBold', 'Heiti TC', sans-serif";
      
      const chartColors = ['#f7ff00', '#cc7a00', '#a231ff', '#19d1ff'];
      const chartLabels = ['6星', '5星', '4星', '3星'];
      
      const starcountsData = <%- JSON.stringify(stats.starcounts) %>;
      const categories = ['所有卡池', '限定尋訪', '標準尋訪', '中堅尋訪', '其他尋訪'];
      
      categories.forEach((cat, index) => {
          let c = starcountsData[cat];
          if(c && (c['5'] + c['4'] + c['3'] + c['2'] > 0)) {
              let ctx = document.getElementById('chart-pie-' + index);
              if (ctx) {
                  new Chart(ctx, {
                      type: 'pie',
                      data: {
                          labels: chartLabels,
                          datasets: [{
                              data: [c['5'], c['4'], c['3'], c['2']],
                              backgroundColor: chartColors,
                              hoverOffset: 4,
                              borderWidth: 0
                          }]
                      },
                      options: {
                          responsive: false,
                          plugins: {
                              legend: {
                                  position: 'right',
                                  labels: { color: '#fff' }
                              },
                              tooltip: {
                                  callbacks: {
                                      label: function(context) {
                                          let label = context.label || '';
                                          if (label) { label += ': '; }
                                          if (context.parsed !== null) {
                                              let total = context.dataset.data.reduce((a, b) => a + b, 0);
                                              let percent = ((context.parsed / total) * 100).toFixed(1) + '%';
                                              label += context.parsed + ' (' + percent + ')';
                                          }
                                          return label;
                                      }
                                  }
                              }
                          }
                      }
                  });
              }
          }
      });

      // Checkbox filter functionality
      const cbs = document.querySelectorAll('.pool-filter-cb');
      const toggleAll = document.getElementById('filter-pool-all');

      if (toggleAll) {
        toggleAll.addEventListener('change', function() {
          const show = this.checked;
          cbs.forEach(cb => {
            if (cb.checked !== show) {
              cb.checked = show;
              cb.dispatchEvent(new Event('change'));
            }
          });
        });
      }

      cbs.forEach(cb => {
        cb.addEventListener('change', function() {
          const poolName = this.value;
          const show = this.checked;
          
          if (toggleAll) {
            const allChecked = Array.from(cbs).every(c => c.checked);
            const someChecked = Array.from(cbs).some(c => c.checked);
            toggleAll.checked = allChecked;
            toggleAll.indeterminate = someChecked && !allChecked;
          }

          document.querySelectorAll(`.pool-group-wrapper[data-pool="${poolName}"]`).forEach(wrapper => {
            wrapper.style.display = show ? 'block' : 'none';
          });
        });
      });
    </script>
    <!-- Global Footer Menu -->
    <div id="footer-menu-container" style="position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 99999; font-family: sans-serif; user-select: none;">
      <div id="footer-menu-links" style="display: none; flex-direction: column; align-items: flex-end; margin-bottom: 0.5rem; gap: 0.5rem;">
        <a href="https://github.com/kaihuang1122/Arknights-txwy-Gacha-Analyze" target="_blank" style="background: rgba(0,0,0,0.8); color: #1bd1fe; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; border: 1px solid #1bd1fe; font-size: 0.9rem; white-space: nowrap; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.2)'" onmouseout="this.style.background='rgba(0,0,0,0.8)'">GitHub 原始碼</a>
        <a href="/privacy" style="background: rgba(0,0,0,0.8); color: #1bd1fe; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; border: 1px solid #1bd1fe; font-size: 0.9rem; white-space: nowrap; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.2)'" onmouseout="this.style.background='rgba(0,0,0,0.8)'">隱私權政策</a>
        <a href="javascript:void(0);" onclick="document.body.scrollTo({top: 0, behavior: 'smooth'}); document.documentElement.scrollTo({top: 0, behavior: 'smooth'}); window.scrollTo({top: 0, behavior: 'smooth'});" style="background: rgba(0,0,0,0.8); color: #1bd1fe; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; border: 1px solid #1bd1fe; font-size: 0.9rem; white-space: nowrap; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.2)'" onmouseout="this.style.background='rgba(0,0,0,0.8)'">↑ 回到頁首</a>
      </div>
      <div id="footer-menu-toggle" style="background: rgba(0, 0, 0, 0.8); width: 3rem; height: 3rem; border-radius: 50%; display: flex; justify-content: center; align-items: center; cursor: pointer; border: 2px solid #1bd1fe; float: right; transition: all 0.3s; color: #1bd1fe; font-size: 1.2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
        ▼
      </div>
    </div>
    <script>
      document.getElementById('footer-menu-toggle').addEventListener('click', function(e) {
        const links = document.getElementById('footer-menu-links');
        if (links.style.display === 'none') {
          links.style.display = 'flex';
          this.innerHTML = '▲';
          this.style.background = 'rgba(27, 209, 254, 0.2)';
        } else {
          links.style.display = 'none';
          this.innerHTML = '▼';
          this.style.background = 'rgba(0, 0, 0, 0.8)';
        }
        e.stopPropagation();
      });
      document.addEventListener('click', function(e) {
        const links = document.getElementById('footer-menu-links');
        const toggle = document.getElementById('footer-menu-toggle');
        if (links && links.style.display === 'flex' && !document.getElementById('footer-menu-container').contains(e.target)) {
          links.style.display = 'none';
          toggle.innerHTML = '▼';
          toggle.style.background = 'rgba(0, 0, 0, 0.8)';
        }
      });
    </script>
  </body>
</html>
